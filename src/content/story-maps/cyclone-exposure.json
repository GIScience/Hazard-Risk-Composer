    "meta": {
        "id": "cyclone-story-map",
        "type": "story-map",
        "version": 1,
        "locale": "en",
        "updatedAt": "2026-07-07",
        "notes": ""
    },
    "storyMap": {
        "hero": {
            "image": "/floods.jpg",
            "alt": "Cyclone Story Map",
            "title": "Cyclone Exposure For Myanmar, Thailand",
            "subtitle": "This Story Map illustrates how we translate complex wind-speed models into clear, actionable data to prioritize humanitarian aid for the most vulnerable populations. When a cyclone strikes, extreme winds threaten both lives and infrastructure. This guide explains how we merge global wind hazard models with population grids to pinpoint exactly where vulnerable communities face the highest risk."
        },
        "sidebar": {
            "icon": "mdi-weather-hurricane",
            "title": "Cyclone Exposure",
            "subtitle": "Understand how cyclone exposure indicators are produced and what they mean",
            "steps": [
                {
                    "number": 1,
                    "sectionRef": "sec-scenario",
                    "title": "Choose a cyclone scenario (Return period)",
                    "body": " We use modelled tropical cyclone wind data from global standard models **(e.g., the Global Model of Cyclone Wind or the Columbia Tropical Cyclone Hazard model - CHAZ)**"
                },
                {
                    "number": 2,
                    "sectionRef": "sec-depth",
                    "title": "Apply the wind-speed threshold",
                    "body": "We only count areas where the modelled sustained wind speed is above a defined threshold. In this example: above **119 km/h**."
                },
                {
                    "number": 3,
                    "sectionRef": "sec-overlay",
                    "title": "Overlay population or facilities",
                    "body": "The flood layer is overlaid with population or facility datasets (such as WorldPop 2020) to identify what is located in the flooded area."
                },
                {
                    "number": 4,
                    "sectionRef": "sec-group",
                    "title": "Focus on a population group",
                    "body": "We can calculate exposure for specific groups.\n\nIn this example: **children under 5 years**."
                },
                {
                    "number": 5,
                    "sectionRef": "sec-aggregate",
                    "title": "Aggregate to administrative areas",
                    "body": "Results are aggregated to ADM2 (district) level to allow comparison between areas and support planning and decision-making."
                }
            ],
            "aside": {
                "variant": "info",
                "icon": "mdi-information",
                "title": "About this story map",
                "body": "This page explains the concept behind flood exposure indicators. Numbers are examples for illustration only."
            }
        },
        "header": {
            "title": "The Core Concept: What does \u201cchildren under 5 exposed to a 50-year cyclone event above 19 km/h\u201d mean ?",
            "description": "The Concept: It estimates how many children under 5 are living in areas that could be hit by extreme winds of more than 119 km/h (Category 1 hurricane force) during a cyclone that has a 1% chance of being exceeded in any given year. Basically, Cyclone Wind Hazard + Population = Exposed Population."
        },
        "sections": [
            {
                "id": "sec-scenario",
                "number": 1,
                "title": "Flood scenario (return period)",
                "hasInfoIcon": true,
                "icon": "mdi-water",
                "control": {
                    "type": "segmented",
                    "id": "return-period",
                    "options": [
                        {
                            "value": "10",
                            "label": "10-years",
                            "selected": true,
                            "layerConfig": {
                                "type": "raster",
                                "layerId": "flood-extent",
                                "colorScheme": "BrewerBlues9",
                                "mode": "ramp",
                                "sourceUrl": "https://hot.storage.heigit.org/heigit-hdx-public/risk_assessment_inputs/storymaps_data/MMR_flooded_RP10_cog_3857.tif"
                            }
                        },
                        {
                            "value": "50",
                            "label": "50-years",
                            "layerConfig": {
                                "type": "cog",
                                "layerId": "flood-extent",
                                "colorScheme": "BrewerBlues9",
                                "mode": "ramp",
                                "sourceUrl": "https://hot.storage.heigit.org/heigit-hdx-public/risk_assessment_inputs/storymaps_data/MMR_flooded_RP50_cog_3857.tif"
                            }
                        },
                        {
                            "value": "100",
                            "label": "100-years",
                            "layerConfig": {
                                "type": "raster",
                                "layerId": "flood-extent",
                                "colorScheme": "BrewerBlues9",
                                "mode": "ramp",
                                "sourceUrl": "https://hot.storage.heigit.org/heigit-hdx-public/risk_assessment_inputs/storymaps_data/MMR_flooded_RP100_cog_3857.tif"
                            }
                        },
                        {
                            "value": "500",
                            "label": "500-years",
                            "layerConfig": {
                                "type": "raster",
                                "layerId": "flood-extent",
                                "colorScheme": "BrewerBlues9",
                                "mode": "ramp",
                                "sourceUrl": "https://hot.storage.heigit.org/heigit-hdx-public/risk_assessment_inputs/storymaps_data/MMR_flooded_RP500_cog_3857.tif"
                            }
                        }
                    ]
                },
                "note": {
                    "variant": "info",
                    "icon": "mdi-information",
                    "body": "A \"50-year return period cyclone\" does not mean it happens once every 50 years. It means there is a 1% chance of a tropical cyclone of this wind intensity occurring in any given year. Naturally, a 50-year cyclone covers a larger impact area with extreme winds than a 10-year event."
                },
                "map": {
                    "controls": [
                        "home",
                        "zoom-in",
                        "zoom-out"
                    ],
                    "showOpacityControl": true
                }
            },
