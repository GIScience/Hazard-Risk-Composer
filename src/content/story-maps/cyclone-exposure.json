    "footer": {
        "callouts": [
            {
                "variant": "positive",
                "icon": "check-circle",
                "title": "What this indicator tells us",
                "body": "It estimates how many children under 5 are living in areas that could experience more than 30 cm of flood water during a flood with a 1% annual chance (50-year return period), based on modelled flood data and population estimates."
            },
            {
                "variant": "warning",
                "icon": "alert-triangle",
                "title": "What this indicator does not tell us",
                "items": [
                    "It does not predict when or if the flood will actually occur.",
                    "It does not account for building quality, protection measures, or elevation of buildings.",
                    "It does not reflect local drainage, informal protection structures, or early warning.",
                    "It shows potential exposure, not actual impacts or damages."
                ]
            }
        ]
    }
