                "id": "sec-depth",
                "number": 2,
                "title": "Wind-speed threshold",
                "hasInfoIcon": true,
                "control": {
                    "type": "segmented",
                    "id": "overlay-type",
                    "options": [
                        {
                            "value": "119",
                            "label": "119km/h",
                            "selected": true
                        }
                    ]
                },
                "note": {
                    "variant": "info",
                    "icon": "mdi-information",
                    "body": "Depth matters for survival and logistics. Only grid cells with a flood depth strictly above 30 cm are considered in this indicator, filtering out areas with minor water accumulation"
                },
                "map": {
