  "meta": {
    "id": "flood-exposure-story-map",
    "type": "story-map",
    "version": 1,
    "locale": "en",
    "updatedAt": "2026-07-07",
    "notes": "Text fields support inline markdown. **bold** should be styled with the brand accent (the blue highlights in the design). All colors and example figures are illustrative placeholders."
