  "storyMap": {
    "sidebar": {
      "icon": "flood",
      "title": "Flood Exposure Story Map",
      "subtitle": "Understand how flood exposure indicators are produced and what they mean.",
      "steps": [
        {
          "number": 1,
          "sectionRef": "sec-scenario",
          "title": "Choose a flood scenario",
          "body": "We use modelled flood inundation from the JRC Global Flood Awareness System (GloFAS).\n\nA **50-year return period flood** has a 1% chance of being exceeded in any given year."
        },
        {
          "number": 2,
          "sectionRef": "sec-depth",
          "title": "Apply the flood-depth threshold",
          "body": "We only count areas where modelled flood depth is above a defined threshold.\n\nIn this example: above **30 cm**."
        },
        {
          "number": 3,
          "sectionRef": "sec-overlay",
          "title": "Overlay population or facilities",
          "body": "The flood layer is overlaid with population or facility datasets to identify what is located in the flooded area."
        },
        {
          "number": 4,
          "sectionRef": "sec-group",
          "title": "Focus on a population group",
          "body": "We can calculate exposure for specific groups.\n\nIn this example: **children under 5 years**."
        },
        {
          "number": 5,
          "sectionRef": "sec-aggregate",
          "title": "Aggregate to administrative areas",
          "body": "Results are aggregated to ADM2 (district) level to allow comparison between areas and support planning and decision-making."
        }
      ],
      "aside": {
        "variant": "info",
        "icon": "info",
        "title": "About this story map",
        "body": "This page explains the concept behind flood exposure indicators. Numbers are examples for illustration only."
      }
    },
    "header": {
      "title": "What does \u201cchildren under 5 exposed to a 50-year flood event above 30 cm\u201d mean?",
      "description": "It estimates how many children under 5 are living in areas that could be flooded with more than 30 cm of water during a flood that has a 1% chance of being exceeded in any given year.",
      "equation": {
        "terms": [
          {
            "kind": "operand",
